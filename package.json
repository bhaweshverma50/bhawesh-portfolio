{
  "name": "bhawesh-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Bhawesh — full-stack engineer portfolio (Vite + React + TypeScript)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
