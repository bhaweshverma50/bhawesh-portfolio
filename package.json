    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^4.3.2",
    "gray-matter": "^4.0.3",
    "jsdom": "^25.0.1",
    "marked": "^18.0.4",
    "marked-shiki": "^1.2.1",
    "sanitize-html": "^2.17.4",
    "shiki": "^4.1.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
